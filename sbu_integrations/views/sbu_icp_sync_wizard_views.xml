<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sbu_icp_sync_wizard_form" model="ir.ui.view">
        <field name="name">sbu.icp.sync.wizard.form</field>
        <field name="model">sbu.icp.sync.wizard</field>
        <field name="arch" type="xml">
            <form string="SBU settings (JSON)">
                <p class="text-muted">
                    <strong>Development → Production:</strong> open this screen on <strong>Development</strong>,
                    click <em>Export sbu.* parameters</em>, copy the JSON. On <strong>Production</strong>, paste it here and click
                    <em>Import sbu.* parameters</em>. Administrator access only. If export is empty, save the SBU block once under
                    <strong>Settings</strong>, or use <em>Fill missing code defaults</em> (non-secret values only).
                </p>
                <group>
                    <field name="json_text" widget="text" nolabel="1" placeholder='{"sbu.graph_tenant_id": "..."}'/>
                </group>
                <footer>
                    <button name="action_seed_missing_defaults" type="object" string="Fill missing code defaults" class="btn-secondary"/>
                    <button name="action_export" type="object" string="Export sbu.* parameters" class="btn-secondary"/>
                    <button name="action_import" type="object" string="Import sbu.* parameters" class="btn-primary"/>
                    <button string="Close" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_sbu_icp_sync_wizard" model="ir.actions.act_window">
        <field name="name">SBU settings JSON</field>
        <field name="res_model">sbu.icp.sync.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem
        id="menu_sbu_icp_sync_wizard"
        name="SBU settings JSON (dev → prod)"
        parent="base.menu_administration"
        action="action_sbu_icp_sync_wizard"
        sequence="95"
        groups="base.group_system"
    />
</odoo>
