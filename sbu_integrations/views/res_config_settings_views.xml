<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_inherit_sbu" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.sbu</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="SBU" string="SBU" name="sbu_integrations">
                    <block title="Integrations (placeholders)" name="sbu_integration_block">
                        <setting string="Microsoft Graph tenant ID" help="Placeholder for a future Microsoft Graph bridge.">
                            <field name="sbu_graph_tenant_id"/>
                        </setting>
                        <setting string="Microsoft Graph client ID" help="Placeholder for a future Microsoft Graph bridge.">
                            <field name="sbu_graph_client_id"/>
                        </setting>
                        <setting string="Qonto organisation" help="Placeholder for a future Qonto bridge.">
                            <field name="sbu_qonto_org"/>
                        </setting>
                        <setting string="Logikal API base URL" help="Placeholder for a future Logikal bridge.">
                            <field name="sbu_logikal_base_url"/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
