<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_inherit_sbu" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.sbu</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <group string="SBU integrations (placeholders)" name="sbu_integration_group">
                    <field name="sbu_graph_tenant_id"/>
                    <field name="sbu_graph_client_id"/>
                    <field name="sbu_qonto_org"/>
                    <field name="sbu_logikal_base_url"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
