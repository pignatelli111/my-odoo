<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_company_form_inherit_sbu_sal" model="ir.ui.view">
        <field name="name">res.company.form.inherit.sbu.sal</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='general_info']//field[@name='currency_id']" position="after">
                <separator string="SBU SAL" groups="account.group_account_manager"/>
                <field name="sbu_sal_invoice_post_default" groups="account.group_account_manager"/>
                <field
                    name="sbu_sal_default_tax_ids"
                    widget="many2many_tags"
                    options='{"no_create": True}'
                    groups="account.group_account_manager"
                />
                <field name="sbu_sal_default_retention_percent" groups="account.group_account_manager"/>
                <field name="sbu_sal_retention_account_id" groups="account.group_account_manager"/>
            </xpath>
        </field>
    </record>
</odoo>
