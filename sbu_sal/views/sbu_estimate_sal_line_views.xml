<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sbu_estimate_sal_line_form_sal" model="ir.ui.view">
        <field name="name">sbu.estimate.sal.line.form.sbu_sal</field>
        <field name="model">sbu.estimate.sal.line</field>
        <field name="inherit_id" ref="sbu_estimate.view_sbu_estimate_sal_line_form"/>
        <field name="arch" type="xml">
            <div name="button_box" position="inside">
                <button name="action_view_payment_certificates"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-file-text-o"
                        invisible="certificate_count == 0">
                    <field name="certificate_count" widget="statinfo" string="CDP"/>
                </button>
                <button name="action_view_invoices"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-pencil-square-o"
                        invisible="invoice_count == 0"
                        groups="account.group_account_invoice">
                    <field name="invoice_count" widget="statinfo" string="Invoices"/>
                </button>
            </div>
            <field name="certificate_ref" position="replace">
                <group string="Finance documents (SAL → administration)">
                    <field name="certificate_ref" placeholder="Auto-filled from SAL billing, or type a reference"/>
                    <field name="payment_certificate_ids" widget="many2many_tags" readonly="1"/>
                    <field name="invoice_ids" widget="many2many_tags" readonly="1"
                           groups="account.group_account_invoice"/>
                    <field name="payment_certificate_id" readonly="1"/>
                    <button name="action_open_latest_certificate" type="object"
                            string="Open latest CDP" class="btn-link"
                            invisible="not payment_certificate_id"/>
                    <field name="invoice_id" readonly="1" groups="account.group_account_invoice"/>
                    <button name="action_open_latest_invoice" type="object"
                            string="Open latest invoice" class="btn-link"
                            invisible="not invoice_id"
                            groups="account.group_account_invoice"/>
                </group>
            </field>
        </field>
    </record>

    <record id="view_sbu_estimate_form_sal_contract" model="ir.ui.view">
        <field name="name">sbu.estimate.form.sal.contract.sbu_sal</field>
        <field name="model">sbu.estimate</field>
        <field name="inherit_id" ref="sbu_estimate.view_sbu_estimate_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_refresh_sal_finance_links" type="object"
                        string="Refresh SAL finance links" class="btn-secondary"
                        invisible="not sal_line_ids"
                        title="Rebuild invoice/CDP links on contractual SAL lines after CDP cleanup"/>
            </xpath>
            <xpath expr="//page[@name='sal_lines']//field[@name='certificate_ref']" position="after">
                <field name="payment_certificate_id" readonly="1" optional="show"/>
                <field name="invoice_id" readonly="1" optional="show"
                       groups="account.group_account_invoice"/>
            </xpath>
            <xpath expr="//page[@name='sal_lines']//form//field[@name='certificate_ref']" position="after">
                <field name="payment_certificate_ids" widget="many2many_tags" readonly="1" optional="hide"/>
                <field name="invoice_ids" widget="many2many_tags" readonly="1" optional="hide"
                       groups="account.group_account_invoice"/>
            </xpath>
        </field>
    </record>
</odoo>
