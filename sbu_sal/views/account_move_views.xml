<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form_sbu_sal_invoice" model="ir.ui.view">
        <field name="name">account.move.form.sbu.sal.invoice</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_print_sbu_sal_detail" type="object"
                        class="oe_stat_button" icon="fa-file-pdf-o"
                        invisible="move_type != 'out_invoice' or not sbu_sal_sheet_id">
                    <div class="o_stat_info">
                        <span class="o_stat_text">Dettaglio SAL</span>
                    </div>
                </button>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="SAL SBU" name="sbu_sal_invoice_tab"
                      invisible="move_type != 'out_invoice' or not sbu_sal_sheet_id">
                    <group>
                        <field name="sbu_sal_sheet_id" readonly="1"/>
                        <field name="sbu_sal_cdp_name" readonly="1" string="CDP"/>
                        <field name="sbu_revision_label" readonly="1" string="Commessa (REV)"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
