<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sbu_sal_sheet_line_import_wizard_form" model="ir.ui.view">
        <field name="name">sbu.sal.sheet.line.import.wizard.form</field>
        <field name="model">sbu.sal.sheet.line.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Add lines from contract">
                <sheet>
                    <group>
                        <group>
                            <field name="sheet_id" readonly="1"/>
                            <field name="estimate_id" readonly="1"/>
                            <field name="replace_existing" widget="boolean_toggle"/>
                            <field name="import_scope" widget="radio"/>
                        </group>
                        <group>
                            <field name="available_count" readonly="1"/>
                            <field name="filtered_count" readonly="1"/>
                            <field name="already_on_sheet_count" readonly="1"/>
                            <field name="selected_count" readonly="1"/>
                        </group>
                    </group>
                    <group string="Filter list (optional)">
                        <group>
                            <field name="filter_item_ref" placeholder="e.g. F1"/>
                            <field name="filter_sal_status"/>
                        </group>
                        <group>
                            <field name="filter_uom_type"/>
                            <field name="filter_text" placeholder="Voce, item, description…"/>
                        </group>
                    </group>
                    <p class="text-muted">
                        Set filters, then click <b>Apply filters</b>. Tick <b>Add</b> on the rows
                        to load on this SAL (you can set <b>This SAL %</b> on the sheet after).
                    </p>
                    <div class="mb-2">
                        <button name="action_apply_filters" string="Apply filters" type="object" class="btn-primary"/>
                        <button name="action_select_filtered" string="Select all visible" type="object" class="btn-secondary"/>
                        <button name="action_select_missing_only" string="Select not on SAL yet" type="object" class="btn-secondary"/>
                        <button name="action_select_all_scope" string="Show all &amp; select" type="object" class="btn-secondary"/>
                        <button name="action_clear_filters" string="Clear filters" type="object" class="btn-secondary"/>
                        <button name="action_clear_selection" string="Clear selection" type="object" class="btn-secondary"/>
                    </div>
                    <field name="line_ids" nolabel="1">
                        <list editable="bottom" create="0" delete="0">
                            <field name="selected" widget="boolean_toggle" string="Add"/>
                            <field name="item_ref" readonly="1"/>
                            <field name="name" readonly="1"/>
                            <field name="description" readonly="1" optional="hide"/>
                            <field name="uom_type" optional="show" readonly="1"/>
                            <field name="total_contract" readonly="1"/>
                            <field name="cumulative_pct" optional="show" readonly="1"/>
                            <field name="sal_status" optional="show" readonly="1" widget="badge"/>
                            <field name="contract_line_id" column_invisible="1"/>
                            <field name="currency_id" column_invisible="1"/>
                        </list>
                    </field>
                </sheet>
                <footer>
                    <button name="action_load" string="Add selected lines" type="object" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
