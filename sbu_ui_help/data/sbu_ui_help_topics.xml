<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <!-- ── Estimates list ───────────────────────────────────────────────── -->
    <record id="help_topic_sbu_estimate_list" model="sbu.ui.help.topic">
        <field name="name">Estimates — list</field>
        <field name="model">sbu.estimate</field>
        <field name="view_mode">list</field>
        <field name="sequence">1</field>
        <field name="purpose" type="html">
            <p>This screen lists <strong>all quotes (preventivi)</strong> for Suburban. Use it to open an existing quote or start a new one.</p>
            <p>Columns show revision (REV), customer, site, amounts, commercial scenario and status (Draft / Sent / Won / Lost).</p>
        </field>
    </record>
    <record id="help_item_est_list_new" model="sbu.ui.help.item">
        <field name="topic_id" ref="help_topic_sbu_estimate_list"/>
        <field name="item_type">button</field>
        <field name="sequence">10</field>
        <field name="title">New</field>
        <field name="body" type="html"><p>Create a blank quote. Fill customer, site and ANACO lines on the form.</p></field>
    </record>
    <record id="help_item_est_list_my" model="sbu.ui.help.item">
        <field name="topic_id" ref="help_topic_sbu_estimate_list"/>
        <field name="item_type">filter</field>
        <field name="sequence">20</field>
        <field name="title">My estimates</field>
        <field name="technical_key">my_estimates</field>
        <field name="body" type="html"><p>Shows only quotes where you are the responsible user.</p></field>
    </record>
    <record id="help_item_est_list_latest" model="sbu.ui.help.item">
        <field name="topic_id" ref="help_topic_sbu_estimate_list"/>
        <field name="item_type">filter</field>
        <field name="sequence">30</field>
        <field name="title">Latest revision only</field>
        <field name="technical_key">sbu_latest_revision</field>
        <field name="body" type="html"><p>Hides older REV of the same quote number — useful for day-to-day work.</p></field>
    </record>
    <record id="help_item_est_list_status" model="sbu.ui.help.item">
        <field name="topic_id" ref="help_topic_sbu_estimate_list"/>
        <field name="item_type">filter</field>
        <field name="sequence">40</field>
        <field name="title">Status filters (Draft, Sent, Won, Lost)</field>
        <field name="body" type="html"><p>Filter by workflow state. <strong>Won</strong> quotes can generate a project/job.</p></field>
    </record>

    <!-- ── Estimate form ────────────────────────────────────────────────── -->
    <record id="help_topic_sbu_estimate_form" model="sbu.ui.help.topic">
        <field name="name">Estimate — form</field>
        <field name="model">sbu.estimate</field>
        <field name="view_mode">form</field>
        <field name="sequence">1</field>
        <field name="purpose" type="html">
            <p>The <strong>quote (preventivo)</strong> is the commercial and technical container for a job: ANACO lines, BOM per item, contractual SAL, and offer conditions.</p>
            <p>Typical flow: <em>Draft</em> → import ANACO Excel → check BOM → <em>Send</em> → <em>Won</em> → create <strong>project</strong> and purchasing documents.</p>
        </field>
    </record>
    <record id="help_item_est_form_send" model="sbu.ui.help.item">
        <field name="topic_id" ref="help_topic_sbu_estimate_form"/>
        <field name="item_type">button</field>
        <field name="sequence">10</field>
        <field name="title">Send</field>
        <field name="technical_key">action_send</field>
        <field name="body" type="html"><p>Marks the quote as sent to the customer (state <strong>Sent</strong>). Internal approval may be required first.</p></field>
    </record>
    <record id="help_item_est_form_won" model="sbu.ui.help.item">
        <field name="topic_id" ref="help_topic_sbu_estimate_form"/>
        <field name="item_type">button</field>
        <field name="sequence">20</field>
        <field name="title">Won</field>
        <field name="technical_key">action_won</field>
        <field name="body" type="html"><p>Quote won — enables project creation and RDA/PO from this estimate.</p></field>
    </record>
    <record id="help_item_est_form_revision" model="sbu.ui.help.item">
        <field name="topic_id" ref="help_topic_sbu_estimate_form"/>
        <field name="item_type">button</field>
        <field name="sequence">30</field>
        <field name="title">New revision</field>
        <field name="technical_key">action_new_revision</field>
        <field name="body" type="html"><p>Duplicates the quote with the next REV (REV01, REV02…) linked to the previous revision.</p></field>
    </record>
    <record id="help_item_est_form_anaco" model="sbu.ui.help.item">
        <field name="topic_id" ref="help_topic_sbu_estimate_form"/>
        <field name="item_type">button</field>
        <field name="sequence">40</field>
        <field name="title">Import ANACO Excel</field>
        <field name="technical_key">action_open_anaco_import_wizard</field>
        <field name="body" type="html"><p>Loads rows from the ANACO workbook (items, dimensions, prices, costs).</p></field>
    </record>
    <record id="help_item_est_form_bom" model="sbu.ui.help.item">
        <field name="topic_id" ref="help_topic_sbu_estimate_form"/>
        <field name="item_type">button</field>
        <field name="sequence">50</field>
        <field name="title">Generate BOM from ANACO</field>
        <field name="technical_key">action_generate_bom_from_anaco_costs</field>
        <field name="body" type="html"><p>Creates BOM lines from CAD cost/price columns on ANACO lines (starting point for purchasing).</p></field>
    </record>
    <record id="help_item_est_form_print" model="sbu.ui.help.item">
        <field name="topic_id" ref="help_topic_sbu_estimate_form"/>
        <field name="item_type">button</field>
        <field name="sequence">60</field>
        <field name="title">Print offer</field>
        <field name="technical_key">action_print_offer</field>
        <field name="body" type="html"><p>PDF offer with commercial lines and included/excluded conditions.</p></field>
    </record>
    <record id="help_item_est_form_tab_anaco" model="sbu.ui.help.item">
        <field name="topic_id" ref="help_topic_sbu_estimate_form"/>
        <field name="item_type">tab</field>
        <field name="sequence">100</field>
        <field name="title">ANACO lines</field>
        <field name="technical_key">anaco_lines</field>
        <field name="body" type="html"><p>Item rows (positions, B/H, mq, discounts, client price and cost columns). Green rows need manual dimensions.</p></field>
    </record>
    <record id="help_item_est_form_tab_bom" model="sbu.ui.help.item">
        <field name="topic_id" ref="help_topic_sbu_estimate_form"/>
        <field name="item_type">tab</field>
        <field name="sequence">110</field>
        <field name="title">BOM (ITEM)</field>
        <field name="technical_key">estimate_item_bom</field>
        <field name="body" type="html"><p>Bill of materials per item — used for RDA demand and supplier RFQ.</p></field>
    </record>
    <record id="help_item_est_form_tab_sal" model="sbu.ui.help.item">
        <field name="topic_id" ref="help_topic_sbu_estimate_form"/>
        <field name="item_type">tab</field>
        <field name="sequence">120</field>
        <field name="title">Contractual SAL</field>
        <field name="body" type="html"><p>Contract billing breakdown (items, quantities, unit prices) for customer progress invoices.</p></field>
    </record>
    <record id="help_item_est_form_tab_terms" model="sbu.ui.help.item">
        <field name="topic_id" ref="help_topic_sbu_estimate_form"/>
        <field name="item_type">tab</field>
        <field name="sequence">130</field>
        <field name="title">Commercial terms</field>
        <field name="body" type="html"><p>Payment, retention, inclusions/exclusions shown on the offer PDF.</p></field>
    </record>
    <record id="help_item_est_form_stat_rev" model="sbu.ui.help.item">
        <field name="topic_id" ref="help_topic_sbu_estimate_form"/>
        <field name="item_type">stat</field>
        <field name="sequence">200</field>
        <field name="title">Revisions (smart button)</field>
        <field name="technical_key">action_view_revision_chain</field>
        <field name="body" type="html"><p>Opens all REV of the same quote number.</p></field>
    </record>

    <!-- ── Purchase request list ────────────────────────────────────────── -->
    <record id="help_topic_sbu_pr_list" model="sbu.ui.help.topic">
        <field name="name">Purchase requests — list</field>
        <field name="model">sbu.purchase.request</field>
        <field name="view_mode">list</field>
        <field name="purpose" type="html">
            <p><strong>Purchase requests (RDA / RFQ documents)</strong> group demand before supplier POs. Each document follows a workflow route (LA, LZ, PAN, OSC, …).</p>
        </field>
    </record>
    <record id="help_item_pr_list_filters" model="sbu.ui.help.item">
        <field name="topic_id" ref="help_topic_sbu_pr_list"/>
        <field name="item_type">filter</field>
        <field name="title">Search panel</field>
        <field name="body" type="html"><p>Filter by project, route, technical data state, Item/Topic from Excel structure.</p></field>
    </record>

    <!-- ── Purchase request form ────────────────────────────────────────── -->
    <record id="help_topic_sbu_pr_form" model="sbu.ui.help.topic">
        <field name="name">Purchase request — form</field>
        <field name="model">sbu.purchase.request</field>
        <field name="view_mode">form</field>
        <field name="purpose" type="html">
            <p>One <strong>purchasing document</strong> for a project: lines with dimensions, BOM link, supplier offers, then draft RFQ/PO.</p>
            <p>Complete technical data (dimensions, confirmations) before <strong>Ready for RFQ/PO</strong>.</p>
        </field>
    </record>
    <record id="help_item_pr_form_submit" model="sbu.ui.help.item">
        <field name="topic_id" ref="help_topic_sbu_pr_form"/>
        <field name="item_type">button</field>
        <field name="sequence">10</field>
        <field name="title">Submit / Approve / Done</field>
        <field name="body" type="html"><p>Internal workflow on the request before purchasing executes RFQs.</p></field>
    </record>
    <record id="help_item_pr_form_bom_load" model="sbu.ui.help.item">
        <field name="topic_id" ref="help_topic_sbu_pr_form"/>
        <field name="item_type">button</field>
        <field name="sequence">20</field>
        <field name="title">Add / replace lines from estimate BOM</field>
        <field name="body" type="html"><p>Pulls demand from the won estimate BOM (quantities, loss %, packs).</p></field>
    </record>
    <record id="help_item_pr_form_excel" model="sbu.ui.help.item">
        <field name="topic_id" ref="help_topic_sbu_pr_form"/>
        <field name="item_type">button</field>
        <field name="sequence">30</field>
        <field name="title">Import from Excel</field>
        <field name="body" type="html"><p>Loads lines from a structured Excel sheet (Cosimo workflow).</p></field>
    </record>
    <record id="help_item_pr_form_rfq" model="sbu.ui.help.item">
        <field name="topic_id" ref="help_topic_sbu_pr_form"/>
        <field name="item_type">button</field>
        <field name="sequence">40</field>
        <field name="title">Create draft RFQ(s)</field>
        <field name="body" type="html"><p>Creates draft purchase order(s) per supplier from selected offers.</p></field>
    </record>
    <record id="help_item_pr_form_matrix" model="sbu.ui.help.item">
        <field name="topic_id" ref="help_topic_sbu_pr_form"/>
        <field name="item_type">button</field>
        <field name="sequence">50</field>
        <field name="title">Comparison matrix</field>
        <field name="body" type="html"><p>Compare supplier offers side by side before choosing.</p></field>
    </record>
    <record id="help_item_pr_form_tab_lines" model="sbu.ui.help.item">
        <field name="topic_id" ref="help_topic_sbu_pr_form"/>
        <field name="item_type">tab</field>
        <field name="sequence">100</field>
        <field name="title">Lines</field>
        <field name="body" type="html"><p>Products, L/H/P, mq, BOM link, qty ordered/remaining. Green = manual entry pending.</p></field>
    </record>
    <record id="help_item_pr_form_tab_offers" model="sbu.ui.help.item">
        <field name="topic_id" ref="help_topic_sbu_pr_form"/>
        <field name="item_type">tab</field>
        <field name="sequence">110</field>
        <field name="title">Supplier offers</field>
        <field name="body" type="html"><p>Enter or import supplier prices per line before RFQ.</p></field>
    </record>

    <!-- ── Project / job form ───────────────────────────────────────────── -->
    <record id="help_topic_project_form" model="sbu.ui.help.topic">
        <field name="name">SBU job — form</field>
        <field name="model">project.project</field>
        <field name="view_mode">form</field>
        <field name="purpose" type="html">
            <p>The <strong>job (commessa)</strong> links the won estimate to tasks, logistics, purchasing, SAL and documents.</p>
            <p>Smart buttons at the top open related lists (RDA, transfers, SAL, Logikal, budget…).</p>
        </field>
    </record>
    <record id="help_item_proj_stat_tasks" model="sbu.ui.help.item">
        <field name="topic_id" ref="help_topic_project_form"/>
        <field name="item_type">stat</field>
        <field name="title">Tasks</field>
        <field name="body" type="html"><p>Standard Odoo project tasks and planning.</p></field>
    </record>
    <record id="help_item_proj_stat_pr" model="sbu.ui.help.item">
        <field name="topic_id" ref="help_topic_project_form"/>
        <field name="item_type">stat</field>
        <field name="title">Purchase req.</field>
        <field name="body" type="html"><p>All purchase requests for this job.</p></field>
    </record>
    <record id="help_item_proj_stat_sal" model="sbu.ui.help.item">
        <field name="topic_id" ref="help_topic_project_form"/>
        <field name="item_type">stat</field>
        <field name="title">Customer SAL / Passive SAL</field>
        <field name="body" type="html"><p>Progress billing to client and subcontractor SAL sheets.</p></field>
    </record>
    <record id="help_item_proj_stat_budget" model="sbu.ui.help.item">
        <field name="topic_id" ref="help_topic_project_form"/>
        <field name="item_type">stat</field>
        <field name="title">Purchasing budget</field>
        <field name="body" type="html"><p>ANACO budget vs engaged PO/RDA by cost family (traffic lights).</p></field>
    </record>
    <record id="help_item_proj_tab_sbu" model="sbu.ui.help.item">
        <field name="topic_id" ref="help_topic_project_form"/>
        <field name="item_type">tab</field>
        <field name="title">SBU / Logistics / M365 tabs</field>
        <field name="body" type="html"><p>Extra notebooks: site delivery rules, budget families, document hub, email ingest.</p></field>
    </record>

    <!-- ── Customer SAL list ─────────────────────────────────────────────── -->
    <record id="help_topic_sbu_sal_list" model="sbu.ui.help.topic">
        <field name="name">SAL sheets — list</field>
        <field name="model">sbu.sal.sheet</field>
        <field name="view_mode">list</field>
        <field name="purpose" type="html">
            <p><strong>SAL sheets (customer)</strong>: one row per progress billing (SAL) linked to a job.</p>
            <p>Click <strong>New</strong> to create a SAL on a project, then confirm and invoice from the form.</p>
        </field>
    </record>
    <record id="help_item_sal_list_new" model="sbu.ui.help.item">
        <field name="topic_id" ref="help_topic_sbu_sal_list"/>
        <field name="item_type">button</field>
        <field name="title">New</field>
        <field name="body" type="html"><p>Opens a new SAL sheet — select the job and add lines from contractual SAL items.</p></field>
    </record>

    <!-- ── Customer SAL form ────────────────────────────────────────────── -->
    <record id="help_topic_sbu_sal_form" model="sbu.ui.help.topic">
        <field name="name">Customer SAL — form</field>
        <field name="model">sbu.sal.sheet</field>
        <field name="view_mode">form</field>
        <field name="purpose" type="html">
            <p><strong>Customer SAL (progress billing)</strong>: bill part of the contract value, withhold retention, issue invoice and payment certificate (CDP).</p>
        </field>
    </record>
    <record id="help_item_sal_confirm" model="sbu.ui.help.item">
        <field name="topic_id" ref="help_topic_sbu_sal_form"/>
        <field name="item_type">button</field>
        <field name="title">Confirm</field>
        <field name="body" type="html"><p>Locks the SAL amounts before invoice and CDP.</p></field>
    </record>
    <record id="help_item_sal_invoice" model="sbu.ui.help.item">
        <field name="topic_id" ref="help_topic_sbu_sal_form"/>
        <field name="item_type">button</field>
        <field name="title">Create draft invoice</field>
        <field name="body" type="html"><p>Creates customer invoice with one line per contractual SAL row (+ retention line if configured).</p></field>
    </record>
    <record id="help_item_sal_cdp" model="sbu.ui.help.item">
        <field name="topic_id" ref="help_topic_sbu_sal_form"/>
        <field name="item_type">button</field>
        <field name="title">Payment certificate (CDP)</field>
        <field name="body" type="html"><p>Generates CDP document linked to the invoice for the client.</p></field>
    </record>
    <record id="help_item_sal_tab_lines" model="sbu.ui.help.item">
        <field name="topic_id" ref="help_topic_sbu_sal_form"/>
        <field name="item_type">tab</field>
        <field name="title">SAL lines</field>
        <field name="body" type="html"><p>Each line: contract item, % this SAL, amount — tied to estimate contractual SAL.</p></field>
    </record>

</odoo>
