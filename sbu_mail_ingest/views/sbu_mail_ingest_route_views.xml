<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sbu_mail_ingest_route_list" model="ir.ui.view">
        <field name="name">sbu.mail.ingest.route.list</field>
        <field name="model">sbu.mail.ingest.route</field>
        <field name="arch" type="xml">
            <list string="Mail ingest routes">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="project_id" optional="show"/>
                <field name="routing"/>
                <field name="alias_email"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_sbu_mail_ingest_route_form" model="ir.ui.view">
        <field name="name">sbu.mail.ingest.route.form</field>
        <field name="model">sbu.mail.ingest.route</field>
        <field name="arch" type="xml">
            <form string="Mail ingest route">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="active"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group string="Alias">
                            <field name="alias_name" placeholder="vendor-jobcode"/>
                            <field name="alias_email" readonly="1"/>
                        </group>
                    </group>
                    <group string="Routing">
                        <field name="partner_id"/>
                        <field name="project_id"/>
                        <field name="routing"/>
                        <field name="purchase_order_id" invisible="routing != 'fixed_po'" required="routing == 'fixed_po'"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_sbu_mail_ingest_route" model="ir.actions.act_window">
        <field name="name">Mail ingest routes</field>
        <field name="res_model">sbu.mail.ingest.route</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
