<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_project_form_sbu_mail_ingest" model="ir.ui.view">
        <field name="name">project.project.form.sbu.mail.ingest</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.edit_project"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Email / RFQ ingest" name="sbu_mail_ingest" groups="project.group_project_user">
                    <group>
                        <div class="text-muted mb-2" colspan="2">
                            Standard project email aliases create <strong>tasks</strong> from incoming mail.
                            To collect vendor quotes and PDFs on a specific <strong>RFQ or PO</strong>, set an
                            <strong>Inbound address</strong> on that purchase order (Purchase app), or define a
                            <strong>Mail ingest route</strong> (Purchase → Mail ingest routes) for a stable vendor/job alias.
                        </div>
                    </group>
                    <group string="Project task alias (Odoo default)">
                        <field name="alias_name" readonly="0" groups="project.group_project_manager"/>
                        <field name="alias_email" readonly="1"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
