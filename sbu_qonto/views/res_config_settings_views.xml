<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_inherit_sbu_qonto" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.sbu.qonto</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="sbu_integrations.res_config_settings_view_form_inherit_sbu"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@name='sbu_integration_block_other']" position="inside">
                <setting string="Qonto API login" help="Sign-in / login from Qonto integrations (not your email password).">
                    <field name="sbu_qonto_login"/>
                </setting>
                <setting string="Qonto secret key" help="API secret; Qonto remains the bank of record—Odoo only mirrors movements.">
                    <field name="sbu_qonto_secret_key" password="True" groups="account.group_account_manager"/>
                </setting>
                <setting string="Qonto IBAN" help="Bank account IBAN used by GET /v2/transactions.">
                    <field name="sbu_qonto_iban"/>
                </setting>
                <setting string="Qonto sandbox" help="Use staging API host for tests.">
                    <field name="sbu_qonto_use_sandbox"/>
                </setting>
                <setting string="Qonto webhook token" help="Path segment for /qonto/webhook/&lt;token&gt;; must match Qonto webhook URL.">
                    <field name="sbu_qonto_webhook_token" password="True"/>
                </setting>
                <setting string="Qonto import cron" help="Allow the scheduled action to pull recent transactions for this company.">
                    <field name="sbu_qonto_import_enabled"/>
                </setting>
                <div class="mt-2">
                    <button
                        name="action_qonto_import_now"
                        type="object"
                        string="Import Qonto movements now"
                        class="btn-secondary"
                        groups="account.group_account_user"
                    />
                </div>
            </xpath>
        </field>
    </record>
</odoo>
