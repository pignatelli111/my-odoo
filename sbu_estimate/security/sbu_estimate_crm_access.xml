<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Read CRM opportunities for linking on estimates (without requiring full Sales app rights). -->
    <record id="access_crm_lead_sbu_estimate_user" model="ir.model.access">
        <field name="name">crm.lead sbu estimate user</field>
        <field name="model_id" ref="crm.model_crm_lead"/>
        <field name="group_id" ref="group_sbu_estimate_user"/>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="0"/>
        <field name="perm_create" eval="0"/>
        <field name="perm_unlink" eval="0"/>
    </record>

    <record id="rule_crm_lead_sbu_estimate_opportunities" model="ir.rule">
        <field name="name">SBU Estimate: read opportunities for preventivi</field>
        <field name="model_id" ref="crm.model_crm_lead"/>
        <field name="groups" eval="[(4, ref('group_sbu_estimate_user'))]"/>
        <field name="domain_force">['|', ('type', '=', 'opportunity'), ('type', '=', False)]</field>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="0"/>
        <field name="perm_create" eval="0"/>
        <field name="perm_unlink" eval="0"/>
    </record>
</odoo>
