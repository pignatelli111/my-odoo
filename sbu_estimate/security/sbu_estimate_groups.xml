<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- CRM read is granted via sbu_estimate_crm_access.xml (not full Sales / User). -->
    <record id="group_sbu_estimate_user" model="res.groups">
        <field name="name">SBU Estimate User</field>
        <field name="sequence">20</field>
        <field name="privilege_id" ref="sales_team.res_groups_privilege_sales"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        <field name="comment">Create and edit SBU estimates; read CRM opportunities for linking on preventivi.</field>
    </record>

    <record id="group_sbu_estimate_uat_cleanup" model="res.groups">
        <field name="name">SBU UAT cleanup</field>
        <field name="sequence">30</field>
        <field name="privilege_id" ref="sales_team.res_groups_privilege_sales"/>
        <field name="implied_ids" eval="[(4, ref('group_sbu_estimate_user'))]"/>
        <field name="comment">Elimina preventivi di test anche se Vinti, con commessa, SAL e fatture (solo UAT).</field>
    </record>

    <record id="group_sbu_estimate_approver" model="res.groups">
        <field name="name">Approvatore Preventivi SBU</field>
        <field name="sequence">25</field>
        <field name="privilege_id" ref="sales_team.res_groups_privilege_sales"/>
        <field name="implied_ids" eval="[
            (4, ref('group_sbu_estimate_user')),
            (4, ref('group_sbu_estimate_uat_cleanup')),
        ]"/>
        <field name="comment">Può approvare o rifiutare preventivi in approvazione interna.</field>
    </record>
</odoo>
