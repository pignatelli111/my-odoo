<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Estimate sequence: PRV/2026/0001 -->
        <record id="seq_sbu_estimate" model="ir.sequence">
            <field name="name">SBU Estimate</field>
            <field name="code">sbu.estimate</field>
            <field name="prefix">PRV/%(year)s/</field>
            <field name="padding">4</field>
            <field name="number_increment">1</field>
            <field name="use_date_range">True</field>
        </record>

        <!-- Project sequence: used for code P0001_2026 -->
        <record id="seq_sbu_project" model="ir.sequence">
            <field name="name">SBU Project Code</field>
            <field name="code">sbu.project</field>
            <field name="prefix"></field>
            <field name="padding">4</field>
            <field name="number_increment">1</field>
        </record>

    </data>
</odoo>
