<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── List view ──────────────────────────────────────────────────────── -->
    <record id="view_sbu_estimate_list" model="ir.ui.view">
        <field name="name">sbu.estimate.list</field>
        <field name="model">sbu.estimate</field>
        <field name="arch" type="xml">
            <list string="Preventivi"
                  decoration-success="state == 'won'"
                  decoration-danger="state == 'lost'"
                  decoration-muted="state == 'cancelled'">
                <field name="name"/>
                <field name="revision"/>
                <field name="date"/>
                <field name="partner_id"/>
                <field name="job_site"/>
                <field name="total_sqm"/>
                <field name="total_price" widget="monetary"/>
                <field name="total_contract_sal" widget="monetary"/>
                <field name="total_cost" widget="monetary"/>
                <field name="expected_margin_pct"/>
                <field name="probability"/>
                <field name="commercial_scenario" optional="show"/>
                <field name="approval_state" optional="hide"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'won'"
                       decoration-danger="state == 'lost'"
                       decoration-info="state == 'sent'"
                       decoration-warning="state == 'draft'"/>
                <field name="currency_id" column_invisible="1"/>
            </list>
        </field>
    </record>

    <!-- ── Form view ──────────────────────────────────────────────────────── -->
    <record id="view_sbu_estimate_form" model="ir.ui.view">
        <field name="name">sbu.estimate.form</field>
        <field name="model">sbu.estimate</field>
        <field name="arch" type="xml">
            <form string="Preventivo">
                <header>
                    <button name="action_send"
                            string="Invia"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'draft' or (approval_required and approval_state != 'approved')"/>
                    <button name="action_request_internal_approval"
                            string="Richiedi approvazione"
                            type="object"
                            class="btn-secondary"
                            invisible="state != 'draft' or not approval_required or approval_state not in ('na', 'rejected')"/>
                    <button name="action_approve_internal"
                            string="Approva"
                            type="object"
                            class="btn-success"
                            groups="sbu_estimate.group_sbu_estimate_approver"
                            invisible="approval_state != 'pending'"/>
                    <button name="action_reject_internal"
                            string="Rifiuta"
                            type="object"
                            class="btn-danger"
                            groups="sbu_estimate.group_sbu_estimate_approver"
                            invisible="approval_state != 'pending'"/>
                    <button name="action_won"
                            string="Vinto"
                            type="object"
                            class="btn-success"
                            invisible="state not in ('draft','sent')"/>
                    <button name="action_lost"
                            string="Perso"
                            type="object"
                            invisible="state not in ('draft','sent')"/>
                    <button name="action_new_revision"
                            string="Nuova Revisione"
                            type="object"
                            invisible="state == 'cancelled'"/>
                    <button name="action_reset_draft"
                            string="Riporta in Bozza"
                            type="object"
                            invisible="state not in ('sent','lost')"/>
                    <button name="action_open_anaco_import_wizard"
                            string="Importa Excel ANACO"
                            type="object"
                            class="btn-secondary"/>
                    <field name="state"
                           widget="statusbar"
                           statusbar_visible="draft,sent,won"/>
                </header>

                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_revision_chain"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-code-fork"
                                invisible="revision_same_name_count == 0">
                            <field name="revision_same_name_count" widget="statinfo" string="Revisioni"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                            <span> — </span>
                            <field name="revision"/>
                        </h1>
                    </div>

                    <group>
                        <group string="Intestazione">
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="partner_id"/>
                            <field name="opportunity_id" groups="sales_team.group_sale_salesman"/>
                            <field name="job_site"/>
                            <field name="user_id"/>
                        </group>
                        <group string="Date e Commerciale">
                            <field name="date"/>
                            <field name="validity_date"/>
                            <field name="validity_days"/>
                            <field name="probability"/>
                            <field name="commercial_scenario"/>
                        </group>
                    </group>

                    <group string="Revisione e approvazione">
                        <group string="Catena revisioni">
                            <field name="previous_revision_id" readonly="1"/>
                            <field name="revision_root_id" readonly="1"/>
                        </group>
                        <group string="Approvazione interna (opzionale)">
                            <field name="approval_required"/>
                            <field name="approval_state"/>
                            <field name="approved_by_id" invisible="approval_state != 'approved'"/>
                            <field name="approved_on" invisible="approval_state != 'approved'"/>
                        </group>
                    </group>

                    <group string="Riepilogo Economico">
                        <group>
                            <field name="total_sqm"/>
                            <field name="total_price" widget="monetary"/>
                            <field name="total_contract_sal" widget="monetary"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                        <group>
                            <field name="total_cost" widget="monetary"/>
                            <field name="margin_amount" widget="monetary"/>
                            <field name="expected_margin_pct"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Righe Preventivo (ANACO)" name="anaco_lines">
                            <field name="line_ids"
                                   context="{'default_estimate_id': id}">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="pos"/>
                                    <field name="description"/>
                                    <field name="calc_uom_type" string="U.M. calcolo"/>
                                    <field name="qty"/>
                                    <field name="width_mm" string="B (mm)"/>
                                    <field name="height_mm" string="H (mm)"/>
                                    <field name="sqm_per_piece" string="MQ/Cad." readonly="1"/>
                                    <field name="sqm" string="Mq tot." readonly="1"/>
                                    <field name="price_serramento_cad"/>
                                    <field name="price_vetro_cad"/>
                                    <field name="price_total_cad" string="Prezzo CAD" readonly="1"/>
                                    <field name="price_total_tot" string="Prezzo TOT" readonly="1"/>
                                    <field name="cost_total_tot" string="Costo TOT" readonly="1"/>
                                </list>
                            </field>
                        </page>

                        <page string="Voci Contrattuali SAL" name="sal_lines">
                            <field name="sal_line_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="item_ref"/>
                                    <field name="description"/>
                                    <field name="uom_type"/>
                                    <field name="qty_contract"/>
                                    <field name="unit_price"/>
                                    <field name="total_contract" readonly="1"/>
                                    <field name="sal_1_pct" string="SAL-1%"/>
                                    <field name="sal_2_pct" string="SAL-2%"/>
                                    <field name="sal_3_pct" string="SAL-3%"/>
                                    <field name="cumulative_pct" string="Cum.%" readonly="1"/>
                                </list>
                            </field>
                        </page>

                        <page string="Allegati e riferimenti" name="estimate_references">
                            <field name="reference_ids"
                                   context="{'default_estimate_id': id}">
                                <list string="Riferimenti" editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="ref_type"/>
                                    <field name="name"/>
                                    <field name="url" widget="url" optional="show"/>
                                    <field name="document_file" filename="document_filename" optional="show"/>
                                    <field name="document_filename" column_invisible="1"/>
                                    <field name="note" optional="hide"/>
                                </list>
                            </field>
                        </page>

                        <page string="Condizioni di Fornitura" name="conditions">
                            <group>
                                <group string="Condizioni Commerciali">
                                    <field name="delivery_terms"/>
                                    <field name="delivery_timing"/>
                                    <field name="payment_terms_text"/>
                                </group>
                                <group string="Validita e Note">
                                    <field name="inclusions"/>
                                    <field name="exclusions"/>
                                </group>
                            </group>
                            <group string="Specifiche Particolari">
                                <field name="special_notes" nolabel="1"/>
                            </group>
                        </page>

                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ── Search view ────────────────────────────────────────────────────── -->
    <record id="view_sbu_estimate_search" model="ir.ui.view">
        <field name="name">sbu.estimate.search</field>
        <field name="model">sbu.estimate</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="job_site"/>
                <filter name="draft"
                        string="Bozza"
                        domain="[('state','=','draft')]"/>
                <filter name="sent"
                        string="Inviato"
                        domain="[('state','=','sent')]"/>
                <filter name="won"
                        string="Vinto"
                        domain="[('state','=','won')]"/>
                <filter name="lost"
                        string="Perso"
                        domain="[('state','=','lost')]"/>
                <filter name="my_estimates"
                        string="Miei Preventivi"
                        domain="[('user_id','=',uid)]"/>
                <filter name="approval_pending"
                        string="In approvazione interna"
                        domain="[('approval_state','=','pending')]"/>
                <separator/>
                <filter name="scenario_base"
                        string="Scenario: Base"
                        domain="[('commercial_scenario','=','base')]"/>
                <filter name="scenario_aggressive"
                        string="Scenario: Aggressivo"
                        domain="[('commercial_scenario','=','aggressive')]"/>
                <filter name="scenario_risk"
                        string="Scenario: Rischio"
                        domain="[('commercial_scenario','=','risk')]"/>
                <filter name="group_partner"
                        string="Raggruppa Cliente"
                        context="{'group_by': 'partner_id'}"/>
                <filter name="group_state"
                        string="Raggruppa Stato"
                        context="{'group_by': 'state'}"/>
                <filter name="group_month"
                        string="Raggruppa Mese"
                        context="{'group_by': 'date:month'}"/>
            </search>
        </field>
    </record>

    <!-- ── Action ─────────────────────────────────────────────────────────── -->
    <record id="action_sbu_estimate" model="ir.actions.act_window">
        <field name="name">Preventivi</field>
        <field name="res_model">sbu.estimate</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_sbu_estimate_search"/>
        <field name="context">{'search_default_my_estimates': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Crea il tuo primo preventivo
            </p>
            <p>
                Inserisci le dimensioni B e H per ogni item e il sistema
                calcola automaticamente mq, quantita e costi.
            </p>
        </field>
    </record>

</odoo>
