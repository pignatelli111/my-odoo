<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_sbu_estimate_to_project_wizard_form" model="ir.ui.view">
        <field name="name">sbu.estimate.to.project.wizard.form</field>
        <field name="model">sbu.estimate.to.project.wizard</field>
        <field name="arch" type="xml">
            <form string="Crea Commessa da Preventivo">
                <sheet>
                    <group string="Preventivo di Origine">
                        <field name="estimate_id" readonly="1"/>
                        <field name="partner_id" readonly="1"/>
                        <field name="job_site" readonly="1"/>
                    </group>
                    <group string="Nuova Commessa">
                        <field name="project_code" readonly="1"/>
                        <field name="project_name"/>
                        <field name="user_id"/>
                        <field name="date_start"/>
                        <field name="date_end"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_create_project"
                            string="Crea Commessa"
                            type="object"
                            class="btn-primary"/>
                    <button string="Annulla" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_sbu_estimate_to_project_wizard" model="ir.actions.act_window">
        <field name="name">Crea Commessa</field>
        <field name="res_model">sbu.estimate.to.project.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
