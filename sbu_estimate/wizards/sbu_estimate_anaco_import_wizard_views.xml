<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_sbu_estimate_anaco_import_wizard_form" model="ir.ui.view">
        <field name="name">sbu.estimate.anaco.import.wizard.form</field>
        <field name="model">sbu.estimate.anaco.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Importa da Excel ANACO">
                <group>
                    <field name="estimate_id" invisible="1"/>
                    <field name="data_file" filename="data_filename"/>
                    <field name="data_filename" invisible="1"/>
                </group>
                <group string="Cosa importare">
                    <field name="import_anaco"/>
                    <field name="replace_anaco_lines" invisible="not import_anaco"/>
                    <field name="import_sal"/>
                    <field name="replace_sal_lines" invisible="not import_sal"/>
                </group>
                <group string="Parametri righe">
                    <field name="auto_detect_first_row" invisible="not import_anaco"/>
                    <field name="import_offerta_fallback" invisible="not import_anaco"/>
                    <field name="anaco_first_row" invisible="not import_anaco"/>
                    <field name="sal_first_row" invisible="not import_sal"/>
                    <field name="default_commission_pct" invisible="not import_anaco"/>
                </group>
                <footer>
                    <button name="action_import"
                            string="Importa"
                            type="object"
                            class="btn-primary"
                            data-hotkey="q"/>
                    <button string="Annulla" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_sbu_estimate_anaco_import_wizard" model="ir.actions.act_window">
        <field name="name">Importa da Excel ANACO</field>
        <field name="res_model">sbu.estimate.anaco.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
