<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sbu_bulk_estimate_line_wizard_form" model="ir.ui.view">
        <field name="name">sbu.bulk.estimate.line.wizard.form</field>
        <field name="model">sbu.bulk.estimate.line.wizard</field>
        <field name="arch" type="xml">
            <form string="Apply to estimate lines">
                <group>
                    <field name="apply_scope" widget="radio"/>
                    <field name="target_count" readonly="1"/>
                    <field name="estimate_id" readonly="1" invisible="not estimate_id"/>
                    <field name="line_ids" widget="many2many_tags" readonly="1"
                           invisible="apply_scope != 'selection' or target_count &gt; 40"/>
                </group>
                <p class="text-muted">
                    Filter with the <b>left panel</b> (estimate, cost family, …), then choose
                    <b>All lines matching list filters</b> and tick fields to apply.
                </p>
                <group string="Fields to apply">
                    <label for="apply_cost_family"/>
                    <div class="o_row">
                        <field name="apply_cost_family" nolabel="1"/>
                        <field name="cost_family" nolabel="1" invisible="not apply_cost_family"
                               required="apply_cost_family"/>
                    </div>
                    <label for="apply_calc_uom"/>
                    <div class="o_row">
                        <field name="apply_calc_uom" nolabel="1"/>
                        <field name="calc_uom_type" nolabel="1" invisible="not apply_calc_uom"
                               required="apply_calc_uom"/>
                    </div>
                </group>
                <footer>
                    <button name="action_apply" string="Apply" type="object" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_sbu_bulk_estimate_line_wizard" model="ir.actions.act_window">
        <field name="name">Apply to selected lines</field>
        <field name="res_model">sbu.bulk.estimate.line.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="model_sbu_estimate_line"/>
        <field name="binding_view_types">list</field>
    </record>
    <record id="action_sbu_bulk_estimate_line_wizard_filtered" model="ir.actions.act_window">
        <field name="name">Apply to filtered result</field>
        <field name="res_model">sbu.bulk.estimate.line.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_apply_scope': 'filtered'}</field>
        <field name="binding_model_id" ref="model_sbu_estimate_line"/>
        <field name="binding_view_types">list</field>
    </record>

