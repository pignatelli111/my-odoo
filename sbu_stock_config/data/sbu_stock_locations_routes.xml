<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- SBU sublocations (under standard WH stock / input from warehouse0) -->
        <record id="stock_location_sbu_reception_buffer" model="stock.location">
            <field name="name">SBU / Reception buffer</field>
            <field name="usage">internal</field>
            <field name="location_id" ref="stock.stock_location_company"/>
            <field name="company_id" ref="base.main_company"/>
        </record>

        <record id="stock_location_sbu_internal_staging" model="stock.location">
            <field name="name">SBU / Internal staging</field>
            <field name="usage">internal</field>
            <field name="location_id" ref="stock.stock_location_stock"/>
            <field name="company_id" ref="base.main_company"/>
        </record>

        <record id="stock_location_sbu_site" model="stock.location">
            <field name="name">SBU / Site (cantiere)</field>
            <field name="usage">internal</field>
            <field name="location_id" ref="stock.stock_location_stock"/>
            <field name="company_id" ref="base.main_company"/>
        </record>

        <!-- Internal route: staging → site (selectable on product / category / warehouse) -->
        <record id="route_sbu_internal_site" model="stock.route">
            <field name="name">SBU — Internal site transfer</field>
            <field name="sequence">25</field>
            <field name="company_id" ref="base.main_company"/>
            <field name="product_selectable" eval="True"/>
            <field name="product_categ_selectable" eval="True"/>
            <field name="warehouse_selectable" eval="True"/>
        </record>

        <record id="stock_rule_sbu_internal_staging_to_site" model="stock.rule">
            <field name="name">SBU: Internal staging → Site</field>
            <field name="route_id" ref="route_sbu_internal_site"/>
            <field name="sequence">20</field>
            <field name="action">pull</field>
            <field name="warehouse_id" ref="stock.warehouse0"/>
            <field name="company_id" ref="base.main_company"/>
            <field name="location_src_id" ref="stock_location_sbu_internal_staging"/>
            <field name="location_dest_id" ref="stock_location_sbu_site"/>
            <field name="picking_type_id" ref="stock.picking_type_internal"/>
            <field name="procure_method">make_to_stock</field>
        </record>
    </data>
</odoo>
