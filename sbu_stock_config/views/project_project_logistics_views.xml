<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_project_form_inherit_sbu_logistics" model="ir.ui.view">
        <field name="name">project.project.form.inherit.sbu.logistics</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.edit_project"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_sbu_view_pickings" type="object" class="oe_stat_button" icon="fa-exchange"
                        groups="stock.group_stock_user">
                    <div class="o_stat_info">
                        <span class="o_stat_value">
                            <field name="picking_count"/>
                        </span>
                        <span class="o_stat_text">Transfers</span>
                    </div>
                </button>
                <button name="action_sbu_view_purchase_orders" type="object" class="oe_stat_button" icon="fa-shopping-cart"
                        groups="purchase.group_purchase_user">
                    <div class="o_stat_info">
                        <span class="o_stat_value">
                            <field name="purchase_order_count"/>
                        </span>
                        <span class="o_stat_text">Purchases</span>
                    </div>
                </button>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="Logistics" name="sbu_logistics_page" groups="stock.group_stock_user">
                    <group>
                        <field name="sbu_logistics_state" widget="badge"/>
                    </group>
                    <group>
                        <button name="action_sbu_view_pickings" type="object" string="Pickings &amp; deliveries"
                                class="btn-secondary" groups="stock.group_stock_user"/>
                        <button name="action_sbu_view_purchase_orders" type="object" string="Purchase orders"
                                class="btn-secondary" groups="purchase.group_purchase_user"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <record id="view_project_list_inherit_sbu_logistics" model="ir.ui.view">
        <field name="name">project.project.list.inherit.sbu.logistics</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.view_project"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="sbu_logistics_state" optional="show" widget="badge"
                       groups="stock.group_stock_user"/>
            </xpath>
        </field>
    </record>

    <record id="view_project_kanban_inherit_sbu_logistics" model="ir.ui.view">
        <field name="name">project.project.kanban.inherit.sbu.logistics</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.view_project_kanban"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='sequence']" position="before">
                <field name="sbu_logistics_state"/>
            </xpath>
            <xpath expr="//span[@name='partner_name']" position="after">
                <div t-if="record.sbu_logistics_state.raw_value and record.sbu_logistics_state.raw_value != 'none'"
                     class="text-muted small mt-1" groups="stock.group_stock_user">
                    <field name="sbu_logistics_state" widget="badge"/>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
