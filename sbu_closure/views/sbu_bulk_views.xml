<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sbu_closure_requirement_bulk_list" model="ir.ui.view">
        <field name="name">sbu.closure.requirement.bulk.list</field>
        <field name="model">sbu.closure.requirement</field>
        <field name="arch" type="xml">
            <list string="Closure checklist" create="0" delete="0">
                <field name="project_id"/>
                <field name="document_type_id"/>
                <field name="name"/>
                <field name="required"/>
                <field name="state" widget="badge"/>
                <field name="due_date" optional="show"/>
                <field name="user_id" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_sbu_closure_requirement_bulk_search" model="ir.ui.view">
        <field name="name">sbu.closure.requirement.bulk.search</field>
        <field name="model">sbu.closure.requirement</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="project_id"/>
                <field name="document_type_id"/>
                <field name="user_id"/>
                <separator/>
                <filter name="pending" string="To do" domain="[('state', '=', 'pending')]"/>
                <filter name="done" string="Done" domain="[('state', '=', 'done')]"/>
                <filter name="required_only" string="Required" domain="[('required', '=', True)]"/>
                <separator/>
                <filter string="Group by project" name="grp_project" context="{'group_by': 'project_id'}"/>
                <searchpanel>
                    <field name="project_id" string="Project / Job" enable_counters="1" limit="40"/>
                    <field name="state" string="Status" enable_counters="1"/>
                    <field name="document_type_id" string="Document type" enable_counters="1"/>
                </searchpanel>
            </search>
        </field>
    </record>

    <record id="action_sbu_closure_requirement_bulk_list" model="ir.actions.act_window">
        <field name="name">Closure checklist (bulk edit)</field>
        <field name="res_model">sbu.closure.requirement</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_sbu_closure_requirement_bulk_list"/>
        <field name="search_view_id" ref="view_sbu_closure_requirement_bulk_search"/>
        <field name="help" type="html">
            <p>Filter by project, status, or document type, then bulk-set status,
               due date, or responsible user on all filtered lines.</p>
        </field>
    </record>

    <record id="view_sbu_closure_requirement_bulk_wizard_form" model="ir.ui.view">
        <field name="name">sbu.closure.requirement.bulk.wizard.form</field>
        <field name="model">sbu.closure.requirement.bulk.wizard</field>
        <field name="arch" type="xml">
            <form string="Apply to closure lines">
                <group>
                    <field name="apply_scope" widget="radio"/>
                    <field name="target_count" readonly="1"/>
                    <field name="project_id" readonly="1" invisible="not project_id"/>
                </group>
                <group string="Fields to apply">
                    <label for="apply_state"/>
                    <div class="o_row">
                        <field name="apply_state" nolabel="1"/>
                        <field name="state" nolabel="1" invisible="not apply_state" required="apply_state"/>
                    </div>
                    <label for="apply_required"/>
                    <div class="o_row">
                        <field name="apply_required" nolabel="1"/>
                        <field name="required" nolabel="1" invisible="not apply_required" required="apply_required"/>
                    </div>
                    <label for="apply_due_date"/>
                    <div class="o_row">
                        <field name="apply_due_date" nolabel="1"/>
                        <field name="due_date" nolabel="1" invisible="not apply_due_date" required="apply_due_date"/>
                    </div>
                    <label for="apply_user_id"/>
                    <div class="o_row">
                        <field name="apply_user_id" nolabel="1"/>
                        <field name="user_id" nolabel="1" invisible="not apply_user_id" required="apply_user_id"/>
                    </div>
                </group>
                <footer>
                    <button name="action_apply" string="Apply" type="object" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_sbu_closure_requirement_bulk_wizard" model="ir.actions.act_window">
        <field name="name">Apply to selected lines</field>
        <field name="res_model">sbu.closure.requirement.bulk.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="model_sbu_closure_requirement"/>
        <field name="binding_view_types">list</field>
    </record>
    <record id="action_sbu_closure_requirement_bulk_wizard_filtered" model="ir.actions.act_window">
        <field name="name">Apply to filtered result</field>
        <field name="res_model">sbu.closure.requirement.bulk.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_apply_scope': 'filtered'}</field>
        <field name="binding_model_id" ref="model_sbu_closure_requirement"/>
        <field name="binding_view_types">list</field>
    </record>

    <menuitem id="menu_sbu_closure_root"
              name="Closure"
              parent="sbu_estimate.menu_sbu_root"
              sequence="50"/>

    <menuitem id="menu_sbu_closure_requirement_bulk"
              name="Checklist lines (bulk edit)"
              parent="menu_sbu_closure_root"
              action="action_sbu_closure_requirement_bulk_list"
              sequence="10"/>
</odoo>
