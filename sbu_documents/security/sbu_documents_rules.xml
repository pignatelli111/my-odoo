        <record id="sbu_external_document_rule_multicompany" model="ir.rule">
            <field name="name">SBU external documents: multi-company</field>
            <field name="model_id" ref="model_sbu_external_document"/>
            <field name="domain_force">['|', ('project_id.company_id', '=', False), ('project_id.company_id', 'in', company_ids)]</field>
        </record>
        <record id="sbu_graph_drive_item_rule_multicompany" model="ir.rule">
            <field name="name">SBU Graph drive items: multi-company</field>
            <field name="model_id" ref="model_sbu_graph_drive_item"/>
            <field name="domain_force">['|', ('project_id.company_id', '=', False), ('project_id.company_id', 'in', company_ids)]</field>
        </record>
    </data>
</odoo>
