<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_project_form_sbu_m365_collaboration" model="ir.ui.view">
        <field name="name">project.project.form.sbu.m365.collaboration</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.edit_project"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="M365 collaboration" name="sbu_m365_collaboration" groups="project.group_project_user">
                    <group>
                        <div class="text-muted mb-2" colspan="2">
                            Pragmatic bridge to Microsoft 365: deep links and short notes only.
                            Keep meetings, threaded chat, and Planner boards in Teams and Planner;
                            use Odoo tasks when you need internal tracking, with an optional link to the same item in M365.
                            Company policy text lives under <em>Settings, SBU, Teams / Planner / Outlook policy</em>.
                        </div>
                    </group>
                    <group>
                        <group string="Microsoft Teams">
                            <field name="sbu_teams_team_url" widget="url"/>
                            <field name="sbu_teams_channel_url" widget="url"/>
                            <field name="sbu_teams_shared_channel_note" placeholder="Shared channel naming, guests, who owns the team…"/>
                        </group>
                        <group string="Planner and Outlook">
                            <field name="sbu_planner_plan_url" widget="url"/>
                            <field name="sbu_outlook_calendar_url" widget="url"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
