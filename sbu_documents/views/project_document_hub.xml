<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_project_form_sbu_documents" model="ir.ui.view">
        <field name="name">project.project.form.sbu.documents</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.edit_project"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Document hub" name="sbu_document_hub">
                    <group>
                        <div class="text-muted mb-3">
                            Operational files stay in OneDrive. Paste the project folder URL below; add extra links (Logikal, drawings) in the list.
                        </div>
                        <field name="sbu_onedrive_url" widget="url" string="OneDrive folder URL"/>
                    </group>
                    <field name="sbu_external_document_ids">
                        <list editable="bottom">
                            <field name="sequence" widget="handle"/>
                            <field name="name"/>
                            <field name="url" widget="url"/>
                            <field name="note" optional="hide"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
