<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_project_form_sbu_documents" model="ir.ui.view">
        <field name="name">project.project.form.sbu.documents</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.edit_project"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Document hub" name="sbu_document_hub">
                    <group>
                        <div class="text-muted mb-3">
                            Operational files stay in OneDrive. Paste the project folder URL below; future automation will sync metadata and links.
                        </div>
                        <field name="sbu_onedrive_url" widget="url" string="OneDrive folder URL"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
