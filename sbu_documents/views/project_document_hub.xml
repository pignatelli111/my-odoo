<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_project_form_sbu_documents" model="ir.ui.view">
        <field name="name">project.project.form.sbu.documents</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.edit_project"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Document hub" name="sbu_document_hub" groups="project.group_project_user">
                    <group>
                        <div class="text-muted mb-2" colspan="2">
                            Operational files live in Microsoft 365 (OneDrive / SharePoint). Use the
                            <strong>suggested folder name</strong> when creating the library folder, paste the
                            <strong>web URL</strong> below, and assign a <strong>custodian</strong> for access reviews.
                            Company naming rules and ownership policy: <em>Settings, SBU, OneDrive / SharePoint</em>.
                        </div>
                    </group>
                    <group>
                        <group string="OneDrive folder">
                            <field name="sbu_onedrive_folder_name_suggested" readonly="1"/>
                            <field name="sbu_onedrive_folder_name_override"/>
                            <field name="sbu_onedrive_folder_name_effective" readonly="1"/>
                        </group>
                        <group string="Link &amp; custody">
                            <field name="sbu_onedrive_url" widget="url" string="OneDrive folder URL"/>
                            <field name="sbu_onedrive_custodian_id" widget="many2one_avatar_user"/>
                            <field name="sbu_onedrive_linked_at" readonly="1" groups="project.group_project_manager"/>
                        </group>
                    </group>
                    <group string="Microsoft Graph IDs (administrators)" groups="project.group_project_manager" colspan="2">
                        <field name="sbu_onedrive_drive_id" placeholder="Drive id from Graph"/>
                        <field name="sbu_onedrive_item_id" placeholder="Root folder item id"/>
                    </group>
                    <group string="Microsoft Graph (folder sync)" colspan="2">
                        <button name="action_sbu_graph_sync_onedrive_folder" type="object"
                                string="Sync folder from Graph" class="btn-secondary"
                                invisible="not sbu_onedrive_drive_id or not sbu_onedrive_item_id"/>
                        <field name="sbu_graph_sync_state" readonly="1"/>
                        <field name="sbu_graph_folder_sync_at" readonly="1"/>
                        <field name="sbu_graph_folder_web_url" widget="url" readonly="1"/>
                        <field name="sbu_graph_sync_message" readonly="1"/>
                    </group>
                    <field name="sbu_graph_drive_item_ids" nolabel="1" colspan="2"
                           options="{'no_create': True, 'no_create_edit': True}">
                        <list string="Indexed items">
                            <field name="name"/>
                            <field name="is_folder"/>
                            <field name="mime_type" optional="show"/>
                            <field name="size" optional="hide"/>
                            <field name="graph_modified" optional="hide"/>
                            <field name="web_url" widget="url"/>
                        </list>
                    </field>
                    <field name="sbu_external_document_ids">
                        <list editable="bottom">
                            <field name="sequence" widget="handle"/>
                            <field name="link_kind"/>
                            <field name="name"/>
                            <field name="url" widget="url"/>
                            <field name="custodian_id" widget="many2one_avatar_user" optional="show"/>
                            <field name="note" optional="hide"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
