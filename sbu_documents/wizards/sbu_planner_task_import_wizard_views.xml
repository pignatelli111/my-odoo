<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sbu_planner_task_import_wizard_form" model="ir.ui.view">
        <field name="name">sbu.planner.task.import.wizard.form</field>
        <field name="model">sbu.planner.task.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Import Planner tasks (CSV)">
                <group>
                    <field name="project_id" readonly="1"/>
                    <field name="data_file" filename="filename"/>
                    <field name="filename" invisible="1"/>
                    <field name="delimiter"/>
                </group>
                <p class="text-muted">
                    Export tasks from Microsoft Planner (or prepare a CSV with columns
                    <em>Title</em>, optional <em>Bucket</em>, <em>Due date</em>, <em>Assigned</em>, <em>Link</em>.
                    Odoo tasks stay the internal checklist; Planner remains the live board via the project URL.
                </p>
                <footer>
                    <button name="action_import" string="Import tasks" type="object" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
