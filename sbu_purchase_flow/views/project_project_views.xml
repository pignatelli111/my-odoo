<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_project_form_sbu_purchase" model="ir.ui.view">
        <field name="name">project.project.form.sbu.purchase</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.edit_project"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_sbu_purchase_requests" type="object" class="oe_stat_button" icon="fa-truck">
                    <div class="o_stat_info">
                        <span class="o_stat_value">
                            <field name="sbu_purchase_request_count"/>
                        </span>
                        <span class="o_stat_text">Purchase req.</span>
                    </div>
                </button>
                <button name="action_sbu_create_demand_rda_from_estimate" type="object"
                        class="oe_stat_button" icon="fa-cubes"
                        invisible="not sbu_estimate_id or sbu_estimate_id.state != 'won'"
                        title="Create an RDA and load demand lines from the won estimate BOM (loss %%, packs, MOQ).">
                    <div class="o_stat_info">
                        <span class="o_stat_text">Demand RDA</span>
                    </div>
                </button>
                <button name="action_sbu_open_purchase_request_create_wizard" type="object"
                        class="oe_stat_button" icon="fa-file-text-o"
                        invisible="not sbu_estimate_id"
                        title="Wizard guidato: LA, LZ, ST, PAN, OSC, VT, ACO, ACP, LDS (un documento per route).">
                    <div class="o_stat_info">
                        <span class="o_stat_text">Nuovo doc.</span>
                    </div>
                </button>
                <button name="action_sbu_create_purchase_requests_by_workflow" type="object"
                        class="oe_stat_button" icon="fa-sitemap"
                        invisible="not sbu_estimate_id or sbu_estimate_id.state != 'won'"
                        title="Create one purchase request per ANACO workflow route (VC/VS, ST, PAN, LA, …).">
                    <div class="o_stat_info">
                        <span class="o_stat_text">By workflow</span>
                    </div>
                </button>
                <button name="action_sbu_open_budget_dashboard" type="object"
                        class="oe_stat_button" icon="fa-pie-chart"
                        invisible="not sbu_estimate_id"
                        title="Preventivo vs impegnato per famiglia costo (semafori ITEM).">
                    <div class="o_stat_info">
                        <span class="o_stat_text">Budget acquisti</span>
                    </div>
                </button>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="Logistica / delivery" name="sbu_delivery_logistics">
                    <group>
                        <group string="Cantiere">
                            <field name="sbu_site_subcontractor_id"/>
                            <field name="sbu_system_supplier_id"/>
                        </group>
                        <group string="Vetro">
                            <field name="sbu_glass_delivery_mode" widget="radio"/>
                        </group>
                    </group>
                    <div class="mb-2">
                        <button name="action_sbu_apply_delivery_on_all_prs" type="object"
                                string="Applica delivery standard su tutte le RDA"
                                class="btn-secondary"
                                title="Ricalcola DESTINAZIONE su tutte le righe delle richieste acquisto della commessa."/>
                    </div>
                    <p class="text-muted">
                        Alluminio e ACO: percorso tipico sistemista → terzista cantiere (4–5 fermate) → cantiere.
                        Vetro: scegli diretto in cantiere oppure stesso terzista dell’alluminio.
                    </p>
                </page>
                <page string="Budget acquisti" name="sbu_budget_families"
                      invisible="not sbu_estimate_id">
                    <group>
                        <field name="sbu_budget_po_unlock"
                               groups="base.group_system"
                               widget="boolean_toggle"/>
                    </group>
                    <div class="mb-2">
                        <button name="action_sbu_refresh_budget_families" type="object"
                                string="Aggiorna da preventivo e acquisti" class="btn-primary"/>
                        <button name="action_sbu_open_budget_dashboard" type="object"
                                string="Apri cruscotto" class="btn-secondary ms-1"/>
                    </div>
                    <field name="sbu_budget_family_ids" nolabel="1" readonly="1"
                           context="{'default_project_id': id}">
                        <list decoration-success="traffic_light == 'ok'"
                              decoration-warning="traffic_light == 'warning'"
                              decoration-danger="traffic_light == 'over'"
                              create="false" delete="false">
                            <field name="cost_family_label" string="Famiglia"/>
                            <field name="budget_planned" string="Preventivo"/>
                            <field name="amount_open_pr" string="RDA"/>
                            <field name="amount_po_draft" string="PO bozza"/>
                            <field name="amount_po_confirmed" string="PO confermati"/>
                            <field name="amount_engaged" string="Impegnato"/>
                            <field name="amount_residual" string="Residuo"/>
                            <field name="pct_engaged" string="Impegnato %"/>
                            <field name="pct_residual" string="Residuo %"/>
                            <field name="traffic_light" string="Semaforo" widget="badge"
                                   decoration-success="traffic_light == 'ok'"
                                   decoration-warning="traffic_light == 'warning'"
                                   decoration-danger="traffic_light == 'over'"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
