<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_project_form_sbu_purchase" model="ir.ui.view">
        <field name="name">project.project.form.sbu.purchase</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.edit_project"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_sbu_purchase_requests" type="object" class="oe_stat_button" icon="fa-truck">
                    <div class="o_stat_info">
                        <span class="o_stat_value">
                            <field name="sbu_purchase_request_count"/>
                        </span>
                        <span class="o_stat_text">Purchase req.</span>
                    </div>
                </button>
                <button name="action_sbu_create_demand_rda_from_estimate" type="object"
                        class="oe_stat_button" icon="fa-cubes"
                        invisible="not sbu_estimate_id or sbu_estimate_id.state != 'won'"
                        title="Create an RDA and load demand lines from the won estimate BOM (loss %%, packs, MOQ).">
                    <div class="o_stat_info">
                        <span class="o_stat_text">Demand RDA</span>
                    </div>
                </button>
                <button name="action_sbu_open_purchase_request_create_wizard" type="object"
                        class="oe_stat_button" icon="fa-file-text-o"
                        invisible="not sbu_estimate_id"
                        title="Wizard guidato: LA, LZ, ST, PAN, OSC, VT, ACO, ACP, LDS (un documento per route).">
                    <div class="o_stat_info">
                        <span class="o_stat_text">Nuovo doc.</span>
                    </div>
                </button>
                <button name="action_sbu_create_purchase_requests_by_workflow" type="object"
                        class="oe_stat_button" icon="fa-sitemap"
                        invisible="not sbu_estimate_id or sbu_estimate_id.state != 'won'"
                        title="Create one purchase request per ANACO workflow route (VC/VS, ST, PAN, LA, …).">
                    <div class="o_stat_info">
                        <span class="o_stat_text">By workflow</span>
                    </div>
                </button>
            </xpath>
        </field>
    </record>
</odoo>
