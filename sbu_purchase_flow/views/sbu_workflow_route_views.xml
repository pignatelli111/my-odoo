<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sbu_workflow_route_list" model="ir.ui.view">
        <field name="name">sbu.workflow.route.list</field>
        <field name="model">sbu.workflow.route</field>
        <field name="arch" type="xml">
            <list string="Workflow routes" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="code"/>
                <field name="name"/>
                <field name="request_type"/>
                <field name="wizard_enabled"/>
                <field name="require_topic"/>
                <field name="require_need_by"/>
                <field name="default_drawn_by" optional="hide"/>
                <field name="default_author" optional="hide"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_sbu_workflow_route_form" model="ir.ui.view">
        <field name="name">sbu.workflow.route.form</field>
        <field name="model">sbu.workflow.route</field>
        <field name="arch" type="xml">
            <form string="Workflow route">
                <sheet>
                    <group>
                        <field name="code"/>
                        <field name="name"/>
                        <field name="sequence"/>
                        <field name="active"/>
                    </group>
                    <group string="Purchase document">
                        <field name="request_type"/>
                        <field name="wizard_enabled"/>
                        <field name="require_topic"/>
                        <field name="require_need_by"/>
                        <field name="default_drawn_by"/>
                        <field name="default_author"/>
                    </group>
                    <field name="notes" placeholder="Internal note for buyers…"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_sbu_workflow_route" model="ir.actions.act_window">
        <field name="name">Workflow routes</field>
        <field name="res_model">sbu.workflow.route</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
