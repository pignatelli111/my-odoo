<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- VdC catalog -->
    <record id="view_sbu_vdc_catalog_list" model="ir.ui.view">
        <field name="name">sbu.vdc.catalog.list</field>
        <field name="model">sbu.vdc.catalog</field>
        <field name="arch" type="xml">
            <list string="VdC budget codes" editable="bottom">
                <field name="code"/>
                <field name="name"/>
                <field name="pdc_code" optional="hide"/>
                <field name="pdc_label" optional="hide"/>
                <field name="note" optional="hide"/>
                <field name="cost_family"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="action_sbu_vdc_catalog" model="ir.actions.act_window">
        <field name="name">VdC budget catalog</field>
        <field name="res_model">sbu.vdc.catalog</field>
        <field name="view_mode">list</field>
    </record>

    <!-- LDS register -->
    <record id="view_sbu_lds_entry_list" model="ir.ui.view">
        <field name="name">sbu.lds.entry.list</field>
        <field name="model">sbu.lds.entry</field>
        <field name="arch" type="xml">
            <list string="LDS register">
                <field name="project_id" optional="hide"/>
                <field name="lds_number"/>
                <field name="delivery_date"/>
                <field name="pos"/>
                <field name="route_type"/>
                <field name="description"/>
                <field name="article_code"/>
                <field name="product_qty"/>
                <field name="reference_rda"/>
                <field name="reference_acp"/>
                <field name="reference_aco"/>
                <field name="order_number"/>
                <field name="material_present"/>
                <field name="expected_date"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_sbu_lds_entry_form" model="ir.ui.view">
        <field name="name">sbu.lds.entry.form</field>
        <field name="model">sbu.lds.entry</field>
        <field name="arch" type="xml">
            <form string="LDS entry">
                <sheet>
                    <group>
                        <group>
                            <field name="project_id"/>
                            <field name="lds_number"/>
                            <field name="delivery_date"/>
                            <field name="pos"/>
                            <field name="route_type"/>
                            <field name="product_type"/>
                        </group>
                        <group>
                            <field name="reference_rda"/>
                            <field name="reference_acp"/>
                            <field name="reference_aco"/>
                            <field name="order_number"/>
                            <field name="purchase_order_id"/>
                            <field name="state"/>
                            <field name="material_present"/>
                            <field name="expected_date"/>
                        </group>
                    </group>
                    <group>
                        <field name="description"/>
                        <field name="article_code"/>
                        <field name="product_qty"/>
                        <field name="note"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_sbu_lds_entry" model="ir.actions.act_window">
        <field name="name">LDS register</field>
        <field name="res_model">sbu.lds.entry</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Drawing register -->
    <record id="view_sbu_drawing_register_list" model="ir.ui.view">
        <field name="name">sbu.drawing.register.list</field>
        <field name="model">sbu.drawing.register</field>
        <field name="arch" type="xml">
            <list string="Drawing approval register">
                <field name="project_id" optional="hide"/>
                <field name="drawing_code"/>
                <field name="name"/>
                <field name="item"/>
                <field name="revision"/>
                <field name="reference" optional="hide"/>
                <field name="last_emission_date"/>
                <field name="approval_state" widget="badge"
                       decoration-success="approval_state == 'approved'"
                       decoration-warning="approval_state == 'issued'"
                       decoration-muted="approval_state == 'draft'"/>
                <field name="block_purchase"/>
            </list>
        </field>
    </record>

    <record id="view_sbu_drawing_register_form" model="ir.ui.view">
        <field name="name">sbu.drawing.register.form</field>
        <field name="model">sbu.drawing.register</field>
        <field name="arch" type="xml">
            <form string="Drawing">
                <sheet>
                    <group>
                        <group>
                            <field name="project_id"/>
                            <field name="drawing_code"/>
                            <field name="name"/>
                            <field name="item"/>
                            <field name="num"/>
                            <field name="revision"/>
                            <field name="reference"/>
                        </group>
                        <group>
                            <field name="emission_1_date"/>
                            <field name="emission_2_date"/>
                            <field name="emission_3_date"/>
                            <field name="last_emission_date"/>
                            <field name="approval_state"/>
                            <field name="block_purchase"/>
                        </group>
                    </group>
                    <field name="note"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_sbu_drawing_register" model="ir.actions.act_window">
        <field name="name">Drawing register</field>
        <field name="res_model">sbu.drawing.register</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Unified project TMS import wizard -->
    <record id="view_sbu_project_tms_import_wizard_form" model="ir.ui.view">
        <field name="name">sbu.project.tms.import.wizard.form</field>
        <field name="model">sbu.project.tms.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Import TMS Excel">
                <group invisible="result_summary">
                    <field name="project_id" options="{'no_create': True}"/>
                    <field name="data_file" filename="filename"/>
                    <field name="filename" invisible="1"/>
                    <field name="import_kind"/>
                    <field name="update_mode" widget="radio"/>
                    <field name="create_purchase_request"
                           invisible="import_kind not in ('auto', 'rda', 'aco', 'acp')"/>
                    <field name="sync_vdc_catalog"
                           invisible="import_kind not in ('auto', 'rda', 'aco', 'acp', 'vdc')"/>
                    <field name="sync_elenco_routes"
                           invisible="import_kind not in ('auto', 'rda', 'aco', 'acp', 'lds', 'elenco')"/>
                </group>
                <group invisible="not result_summary">
                    <field name="result_summary" nolabel="1" readonly="1"/>
                </group>
                <p class="text-muted" invisible="result_summary">
                    Upload origin TMS files (M.4.3.x RDA/ACO/ACP, M.4.4.x LDS, Report tav appr).
                    Auto-detect reads filename and sheet names. RDA imports also sync the VdC
                    catalog and route owners when those sheets exist.
                </p>
                <footer>
                    <button name="action_import" string="Import" type="object" class="btn-primary"
                            invisible="result_summary"/>
                    <button string="Close" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_sbu_project_tms_import_wizard" model="ir.actions.act_window">
        <field name="name">Import TMS Excel</field>
        <field name="res_model">sbu.project.tms.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
