<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sbu_purchase_request_list" model="ir.ui.view">
        <field name="name">sbu.purchase.request.list</field>
        <field name="model">sbu.purchase.request</field>
        <field name="arch" type="xml">
            <list string="Purchase requests">
                <field name="name"/>
                <field name="priority" widget="badge"
                       decoration-danger="priority == '3'"
                       decoration-warning="priority == '2'"
                       decoration-info="priority == '1'"/>
                <field name="request_type"/>
                <field name="need_by_date" optional="show"/>
                <field name="site_required_date" optional="hide"/>
                <field name="topic" optional="hide"/>
                <field name="project_id"/>
                <field name="estimate_id" optional="hide"/>
                <field name="vendor_id" optional="show"/>
                <field name="demand_loss_pct" optional="hide"/>
                <field name="state" widget="badge"/>
                <field name="user_id" widget="many2one_avatar_user"/>
                <field name="company_id" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="view_sbu_purchase_request_form" model="ir.ui.view">
        <field name="name">sbu.purchase.request.form</field>
        <field name="model">sbu.purchase.request</field>
        <field name="arch" type="xml">
            <form string="Purchase request">
                <header>
                    <button name="action_submit" string="Submit" type="object" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_approve" string="Approve" type="object" invisible="state != 'submitted'"/>
                    <button name="action_done" string="Done" type="object" invisible="state != 'approved'"/>
                    <button name="action_reset_draft" string="Reset to draft" type="object" invisible="state not in ('submitted','approved','cancelled')"/>
                    <button name="action_cancel" string="Cancel" type="object" invisible="state in ('done','cancelled')"/>
                    <button name="action_load_lines_from_estimate_bom_append"
                            string="Add lines from estimate BOM"
                            type="object"
                            class="btn-secondary"
                            invisible="state == 'cancelled'"/>
                    <button name="action_load_lines_from_estimate_bom_replace"
                            string="Replace lines from estimate BOM"
                            type="object"
                            class="btn-secondary"
                            invisible="state == 'cancelled'"/>
                    <button name="action_refresh_all_bom_quantities"
                            string="Refresh BOM quantities"
                            type="object"
                            class="btn-secondary"
                            invisible="state == 'cancelled'"/>
                    <button name="action_create_rfq" string="Create draft RFQ(s)" type="object" class="btn-secondary" invisible="state == 'cancelled'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,submitted,approved,done,cancelled"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_project" type="object" class="oe_stat_button" icon="fa-folder-open"
                                invisible="not project_id">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Project</span>
                            </div>
                        </button>
                    </div>
                    <group>
                        <group string="Request">
                            <field name="name" readonly="1"/>
                            <field name="request_type" readonly="state in ('done','cancelled')"/>
                            <field name="priority" readonly="state in ('done','cancelled')"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="project_id" readonly="state in ('done','cancelled')"/>
                            <field name="estimate_id"/>
                            <field name="vendor_id"/>
                            <field name="vendor_ids" widget="many2many_tags"
                                   readonly="state in ('done','cancelled')"
                                   placeholder="Add suppliers for multi-vendor RFQ…"/>
                            <field name="offer_comparison_markup_pct" readonly="state in ('done','cancelled')"/>
                            <field name="excel_item"/>
                            <field name="topic"/>
                        </group>
                        <group string="People &amp; dates">
                            <field name="user_id" widget="many2one_avatar_user"/>
                            <field name="need_by_date" readonly="state in ('done','cancelled')"/>
                            <field name="site_required_date" readonly="state in ('done','cancelled')"/>
                            <field name="demand_loss_pct" readonly="state in ('done','cancelled')"/>
                            <field name="drawn_by"/>
                            <field name="check_by"/>
                        </group>
                    </group>
                    <group string="Approval" invisible="state == 'draft'">
                        <group>
                            <field name="submitted_date"/>
                        </group>
                        <group>
                            <field name="approved_by_id"/>
                            <field name="approved_date"/>
                            <field name="date_done"/>
                        </group>
                    </group>
                    <group string="Cancellation" invisible="state != 'cancelled'">
                        <field name="cancel_reason" nolabel="1" placeholder="Reason for cancellation…"/>
                    </group>
                    <notebook>
                        <page string="Lines">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="line_priority" optional="show"/>
                                    <field name="pos" optional="show"/>
                                    <field name="name"/>
                                    <field name="article_code" optional="show"/>
                                    <field name="product_id"/>
                                    <field name="source_bom_line_id" optional="show"/>
                                    <field name="bom_qty_sync" optional="show"/>
                                    <field name="bom_qty_ordered_ref" optional="hide"/>
                                    <field name="dimension_mm" optional="hide"/>
                                    <field name="utilization" optional="hide"/>
                                    <field name="weight_kg" optional="hide"/>
                                    <!-- Do not use source_bom_line_id in modifiers: Many2one is not a safe boolean in list views. -->
                                    <field name="product_qty" readonly="bom_qty_sync"/>
                                    <field name="product_uom"/>
                                    <field name="date_required"/>
                                    <field name="destination" optional="hide"/>
                                    <field name="procurement_mode" optional="show"/>
                                    <field name="note" optional="hide"/>
                                    <field name="offer_count" optional="show"/>
                                </list>
                            </field>
                        </page>
                        <page string="Supplier offers">
                            <field name="offer_ids" readonly="state in ('done','cancelled')">
                                <list editable="bottom">
                                    <field name="request_line_id"
                                           domain="[('request_id', '=', parent.id)]"
                                           options="{'no_create': True}"/>
                                    <field name="vendor_id"/>
                                    <field name="name" optional="show"/>
                                    <field name="unit_price"/>
                                    <field name="currency_id" optional="hide"/>
                                    <field name="price_evaluated" optional="show"/>
                                    <field name="offer_date" optional="show"/>
                                    <field name="lead_time_days" optional="hide"/>
                                    <field name="notes" optional="hide"/>
                                    <field name="attachment_ids" widget="many2many_binary" optional="show"/>
                                </list>
                            </field>
                            <div class="text-muted">
                                Capture several quotes per line; attach PDF/Excel from the supplier.
                                «Evaluated price» applies the request «Offer comparison markup %» to the unit price.
                            </div>
                        </page>
                        <page string="Attachments">
                            <group>
                                <field name="attachment_ids" widget="many2many_binary" nolabel="1"
                                       readonly="state in ('done','cancelled')"/>
                                <div class="text-muted" colspan="2">
                                    Use this for supplier PDFs / drawings; chatter below keeps the discussion trail.
                                </div>
                            </group>
                        </page>
                        <page string="Purchase orders">
                            <field name="purchase_order_ids" widget="many2many_tags"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_sbu_purchase_request_search" model="ir.ui.view">
        <field name="name">sbu.purchase.request.search</field>
        <field name="model">sbu.purchase.request</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="project_id"/>
                <field name="request_type"/>
                <field name="user_id"/>
                <filter name="draft" string="Draft" domain="[('state','=','draft')]"/>
                <filter name="submitted" string="Submitted" domain="[('state','=','submitted')]"/>
                <filter name="approved" string="Approved" domain="[('state','=','approved')]"/>
                <filter name="my_requests" string="My requests" domain="[('user_id','=',uid)]"/>
                <separator/>
                <filter name="type_rda" string="RDA" domain="[('request_type','=','rda')]"/>
                <filter name="type_acp" string="ACP" domain="[('request_type','=','acp')]"/>
                <filter name="type_aco" string="ACO" domain="[('request_type','=','aco')]"/>
                <filter name="type_lds" string="LDS" domain="[('request_type','=','lds')]"/>
                <separator/>
                <filter name="prio_high" string="High / critical" domain="[('priority','in', ('2','3'))]"/>
                <filter name="need_by_set" string="Need-by set" domain="[('need_by_date','!=', False)]"/>
                <group expand="0" string="Group By">
                    <filter string="Type" name="grp_type" context="{'group_by': 'request_type'}"/>
                    <filter string="Priority" name="grp_prio" context="{'group_by': 'priority'}"/>
                    <filter string="Project" name="grp_project" context="{'group_by': 'project_id'}"/>
                    <filter string="Status" name="grp_state" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_sbu_purchase_request" model="ir.actions.act_window">
        <field name="name">Purchase requests</field>
        <field name="res_model">sbu.purchase.request</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
