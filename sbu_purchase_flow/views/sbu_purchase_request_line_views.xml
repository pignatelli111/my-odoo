<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sbu_purchase_request_line_list" model="ir.ui.view">
        <field name="name">sbu.purchase.request.line.list</field>
        <field name="model">sbu.purchase.request.line</field>
        <field name="arch" type="xml">
            <list string="Purchase request lines">
                <field name="request_id"/>
                <field name="request_type" optional="show"/>
                <field name="workflow_route" optional="show"/>
                <field name="project_id" optional="show"/>
                <field name="pos" optional="show"/>
                <field name="name"/>
                <field name="article_code" optional="show"/>
                <field name="product_id"/>
                <field name="manual_input_state" column_invisible="1"/>
                <field name="manual_input_pending" column_invisible="1"/>
                <field name="width_mm" string="L (mm)"
                       decoration-success="manual_input_pending and not width_mm"
                       decoration-muted="manual_input_state == 'imported' and width_mm"/>
                <field name="height_mm" string="H (mm)"
                       decoration-success="manual_input_pending and not height_mm"
                       decoration-muted="manual_input_state == 'imported' and height_mm"/>
                <field name="depth_mm" string="P (mm)"
                       decoration-success="manual_input_pending and not depth_mm"
                       decoration-muted="manual_input_state == 'imported' and depth_mm"/>
                <field name="sqm_per_piece" string="MQ/cad"/>
                <field name="sqm_total" string="MQ tot."/>
                <field name="dimension_mm" string="Dimensioni"/>
                <field name="product_qty"/>
                <field name="date_required" optional="show"/>
                <field name="destination" optional="show"/>
                <field name="procurement_mode" optional="show"/>
                <field name="line_priority" optional="show"/>
                <field name="technical_confirmed" optional="hide"/>
                <field name="request_state" column_invisible="1"/>
                <field name="technical_data_state" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_sbu_purchase_request_line_search" model="ir.ui.view">
        <field name="name">sbu.purchase.request.line.search</field>
        <field name="model">sbu.purchase.request.line</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="request_id"/>
                <field name="project_id"/>
                <field name="product_id"/>
                <field name="pos"/>
                <field name="article_code"/>
                <field name="request_type"/>
                <field name="workflow_route"/>
                <field name="destination"/>
                <separator/>
                <filter name="no_delivery_date" string="Senza data consegna"
                        domain="[('date_required', '=', False)]"/>
                <filter name="has_delivery_date" string="Con data consegna"
                        domain="[('date_required', '!=', False)]"/>
                <filter name="date_required_period" string="Data consegna" date="date_required"/>
                <separator/>
                <filter name="pending_technical" string="In attesa conferma tecnica"
                        domain="[('needs_technical_confirm', '=', True), ('technical_confirmed', '=', False)]"/>
                <filter name="manual_input_pending" string="Compilazione manuale (verde)"
                        domain="[('manual_input_pending', '=', True)]"/>
                <filter name="manual_input_imported" string="Da import / Logikal (grigio)"
                        domain="[('manual_input_state', '=', 'imported')]"/>
                <filter name="procurement_purchase" string="Approvv.: acquisto"
                        domain="[('procurement_mode', '=', 'purchase')]"/>
                <filter name="procurement_wh" string="Approvv.: magazzino"
                        domain="[('procurement_mode', '=', 'warehouse')]"/>
                <filter name="prio_high" string="Priorità alta/critica"
                        domain="[('line_priority', 'in', ('2', '3'))]"/>
                <separator/>
                <filter name="type_rda" string="RDA" domain="[('request_type', '=', 'rda')]"/>
                <filter name="type_aco" string="ACO" domain="[('request_type', '=', 'aco')]"/>
                <filter name="type_acp" string="ACP" domain="[('request_type', '=', 'acp')]"/>
                <filter name="type_vt" string="VT / Vetro" domain="[('request_type', '=', 'vt')]"/>
                <filter name="type_st" string="ST" domain="[('request_type', '=', 'st')]"/>
                <filter name="type_fe" string="FE / Carpenteria" domain="[('request_type', '=', 'fe')]"/>
                <separator/>
                <filter name="route_la" string="LA" domain="[('workflow_route', '=', 'LA')]"/>
                <filter name="route_lz" string="LZ" domain="[('workflow_route', '=', 'LZ')]"/>
                <filter name="route_st" string="ST" domain="[('workflow_route', '=', 'ST')]"/>
                <filter name="route_pan" string="PAN" domain="[('workflow_route', '=', 'PAN')]"/>
                <filter name="route_osc" string="OSC" domain="[('workflow_route', '=', 'OSC')]"/>
                <filter name="route_zanz" string="Zanzariere" domain="[('workflow_route', '=', 'ZANZ')]"/>
                <filter name="route_vt" string="VT / VC-VS" domain="[('workflow_route', '=', 'VC/VS')]"/>
                <separator/>
                <filter name="tech_estimate" string="Dati: stima distinta"
                        domain="[('technical_data_state', '=', 'estimate_bom')]"/>
                <filter name="tech_review" string="Dati: revisione tecnica"
                        domain="[('technical_data_state', '=', 'technical_review')]"/>
                <filter name="tech_ready" string="Dati: pronto per PO"
                        domain="[('technical_data_state', '=', 'ready_for_po')]"/>
                <separator/>
                <filter string="Raggruppa per RDA" name="grp_request" context="{'group_by': 'request_id'}"/>
                <filter string="Raggruppa per commessa" name="grp_project" context="{'group_by': 'project_id'}"/>
                <filter string="Raggruppa per tipo" name="grp_type" context="{'group_by': 'request_type'}"/>
                <filter string="Raggruppa per prodotto" name="grp_product" context="{'group_by': 'product_id'}"/>
                <filter string="Raggruppa per data consegna" name="grp_date" context="{'group_by': 'date_required'}"/>
                <filter string="Raggruppa per priorità" name="grp_prio" context="{'group_by': 'line_priority'}"/>
                <searchpanel>
                    <field name="workflow_route" string="Route (LA/LZ/ST/PAN/OSC)" enable_counters="1"/>
                    <field name="request_type" string="Tipo Odoo" enable_counters="1"/>
                    <field name="procurement_mode" string="Approvvigionamento" enable_counters="1"/>
                    <field name="line_priority" string="Priorità riga" enable_counters="1"/>
                    <field name="technical_data_state" string="Dati tecnici" enable_counters="1"/>
                    <field name="project_id" string="Commessa" enable_counters="1" limit="40"/>
                </searchpanel>
            </search>
        </field>
    </record>

    <record id="action_sbu_purchase_request_line" model="ir.actions.act_window">
        <field name="name">Purchase request lines</field>
        <field name="res_model">sbu.purchase.request.line</field>
        <field name="view_mode">list</field>
        <field name="search_view_id" ref="view_sbu_purchase_request_line_search"/>
        <field name="help" type="html">
            <p>Usa i <b>filtri a sinistra</b> (tipo RDA, priorità, data consegna, …), poi
               <b>Azione → Applica al risultato filtrato</b> per impostare data, destinazione,
               magazzino/acquisto e priorità su tutte le righe del filtro (senza selezionarle una a una).</p>
        </field>
    </record>
</odoo>
