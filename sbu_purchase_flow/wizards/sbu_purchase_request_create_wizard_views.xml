<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sbu_purchase_request_create_wizard_form" model="ir.ui.view">
        <field name="name">sbu.purchase.request.create.wizard.form</field>
        <field name="model">sbu.purchase.request.create.wizard</field>
        <field name="arch" type="xml">
            <form string="New purchase document">
                <group>
                    <field name="project_id" options="{'no_create': True}"/>
                    <field name="workflow_route"/>
                    <field name="request_type" readonly="1"/>
                    <field name="priority"/>
                    <field name="need_by_date"/>
                    <field name="topic" placeholder="es. Facciata nord, Piano 2"/>
                    <field name="excel_item" placeholder="es. LA01, PAN03"/>
                    <field name="load_from_estimate"/>
                </group>
                <p class="text-muted">
                    Choose only the supported types (LA, LZ, ST, PAN, OSC, VT, ACO, ACP, LDS).
                    The document starts <b>without lines</b> unless you tick «Load lines from estimate BOM».
                    Use «Add lines from estimate BOM» on the RDA form to pick rows later.
                    Required fields depend on the route: Topic for materials (LA, PAN, …),
                    need-by date for LA/LZ/ST/PAN/OSC/VT. A second open document
                    cannot be created for the same job and route.
                </p>
                <footer>
                    <button name="action_create" string="Create document" type="object" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_sbu_purchase_request_create_wizard" model="ir.actions.act_window">
        <field name="name">Nuovo documento acquisto</field>
        <field name="res_model">sbu.purchase.request.create.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
