<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sbu_purchase_request_create_wizard_form" model="ir.ui.view">
        <field name="name">sbu.purchase.request.create.wizard.form</field>
        <field name="model">sbu.purchase.request.create.wizard</field>
        <field name="arch" type="xml">
            <form string="Nuovo documento acquisto">
                <group>
                    <field name="project_id" options="{'no_create': True}"/>
                    <field name="workflow_route"/>
                    <field name="request_type" readonly="1"/>
                    <field name="priority"/>
                    <field name="need_by_date"/>
                    <field name="topic" placeholder="es. Facciata nord, Piano 2"/>
                    <field name="excel_item" placeholder="es. LA01, PAN03"/>
                    <field name="load_from_estimate"/>
                </group>
                <p class="text-muted">
                    Scegliere solo i tipi previsti (LA, LZ, ST, PAN, OSC, VT, ACO, ACP, LDS).
                    I campi obbligatori dipendono dalla route: Topic per materiali (LA, PAN, …),
                    data fabbisogno per LA/LZ/ST/PAN/OSC/VT. Non si crea un secondo documento
                    aperto con la stessa commessa e route.
                </p>
                <footer>
                    <button name="action_create" string="Crea documento" type="object" class="btn-primary"/>
                    <button string="Annulla" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_sbu_purchase_request_create_wizard" model="ir.actions.act_window">
        <field name="name">Nuovo documento acquisto</field>
        <field name="res_model">sbu.purchase.request.create.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
