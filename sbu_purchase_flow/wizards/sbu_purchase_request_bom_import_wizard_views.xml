<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sbu_purchase_request_bom_import_wizard_form" model="ir.ui.view">
        <field name="name">sbu.purchase.request.bom.import.wizard.form</field>
        <field name="model">sbu.purchase.request.bom.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Load lines from estimate BOM">
                <sheet>
                    <group>
                        <field name="request_id" readonly="1"/>
                        <field name="estimate_id" invisible="1"/>
                        <field name="workflow_route" readonly="1"/>
                        <field name="replace_existing" widget="boolean_toggle"/>
                        <field name="import_scope" widget="radio"/>
                        <field name="available_count" readonly="1"/>
                        <field name="already_linked_count" readonly="1"/>
                        <field name="selected_count" readonly="1"/>
                    </group>
                    <p class="text-muted">
                        If <b>matching route</b> shows 0 lines, switch to <b>All estimate BOM lines</b>
                        or check ANACO rows have the correct cost family / workflow route (e.g. LA).
                    </p>
                    <div class="mb-2">
                        <button name="action_select_route_lines" string="Select all (route)" type="object" class="btn-secondary"/>
                        <button name="action_select_all_estimate" string="Select all (estimate)" type="object" class="btn-secondary"/>
                        <button name="action_select_new_only" string="Select not yet linked" type="object" class="btn-secondary"/>
                        <button name="action_clear_selection" string="Clear selection" type="object" class="btn-secondary"/>
                    </div>
                    <field name="bom_line_ids" nolabel="1"
                           widget="many2many"
                           domain="[('estimate_id', '=', estimate_id)]"
                           context="{'list_view_ref': 'sbu_estimate.view_sbu_estimate_bom_line_list_picker'}"
                           options="{'no_create': True}"/>
                </sheet>
                <footer>
                    <button name="action_load" string="Load selected lines" type="object" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_sbu_purchase_request_bom_import_wizard" model="ir.actions.act_window">
        <field name="name">Load from estimate BOM</field>
        <field name="res_model">sbu.purchase.request.bom.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
