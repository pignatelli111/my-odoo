<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sbu_purchase_request_excel_import_wizard_form" model="ir.ui.view">
        <field name="name">sbu.purchase.request.excel.import.wizard.form</field>
        <field name="model">sbu.purchase.request.excel.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Import RDA lines from Excel">
                <group>
                    <field name="request_id" readonly="1"/>
                    <field name="data_file" filename="filename"/>
                    <field name="filename" invisible="1"/>
                    <field name="template_format"/>
                    <field name="sheet_name" placeholder="Auto: Esempio RDA / ACO / ACP"/>
                    <field name="import_header"/>
                    <field name="sync_vdc_catalog"/>
                    <field name="update_mode" widget="radio"/>
                </group>
                <footer>
                    <button name="action_import" string="Import" type="object" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_sbu_purchase_request_excel_import" model="ir.actions.act_window">
        <field name="name">Import from Excel</field>
        <field name="res_model">sbu.purchase.request.excel.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
